#!/bin/sh
# Maven Wrapper Script (Unix/macOS/Linux)
# ------------------------------------------------------------
set -e

MAVEN_WRAPPER_JAR=".mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES=".mvn/wrapper/maven-wrapper.properties"
MAVEN_PROJECTBASEDIR=$(cd "$(dirname "$0")" && pwd)

# Wrapper JAR 없으면 다운로드
if [ ! -f "$MAVEN_PROJECTBASEDIR/$MAVEN_WRAPPER_JAR" ]; then
  WRAPPER_URL=$(grep 'wrapperUrl' "$MAVEN_PROJECTBASEDIR/$MAVEN_WRAPPER_PROPERTIES" | cut -d= -f2)
  echo "Downloading Maven Wrapper from $WRAPPER_URL"
  curl -o "$MAVEN_PROJECTBASEDIR/$MAVEN_WRAPPER_JAR" "$WRAPPER_URL" 2>/dev/null \
    || wget -O "$MAVEN_PROJECTBASEDIR/$MAVEN_WRAPPER_JAR" "$WRAPPER_URL"
fi

exec java -jar "$MAVEN_PROJECTBASEDIR/$MAVEN_WRAPPER_JAR" "$@"
